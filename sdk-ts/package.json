{
    "name": "@exowarexyz/sdk",
    "version": "2026.4.1",
    "description": "Interact with the Exoware API in TypeScript.",
    "type": "module",
    "license": "(MIT OR Apache-2.0)",
    "homepage": "https://exoware.xyz",
    "repository": {
        "type": "git",
        "url": "https://github.com/exowarexyz/monorepo.git",
        "directory": "sdk-ts"
    },
    "publishConfig": {
        "access": "public"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "lint": "tsc --noEmit",
        "test": "jest --config jest.config.cjs",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@bufbuild/protobuf": "^2.11.0",
        "@connectrpc/connect": "^2.1.1",
        "@connectrpc/connect-web": "^2.1.1"
    },
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "@types/node": "^20.14.9",
        "jest": "^29.7.0",
        "portfinder": "^1.0.32",
        "ts-jest": "^29.2.2",
        "typescript": "^5.5.3"
    }
}